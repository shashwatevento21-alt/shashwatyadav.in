RewriteEngine On

# If someone requests a URL with .html directly, redirect to the clean URL (avoids duplicate content)
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve the matching .html file for a clean URL request, without changing the URL shown in the browser
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [NC,L]
