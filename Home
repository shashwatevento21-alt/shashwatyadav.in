      const submitBtn = event.target.querySelector('button[type="submit"]');
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = '<span>Sending...</span>';
      submitBtn.disabled = true;
      
      // Your Google Sheets Web App URL
      const scriptURL = 'https://script.google.com/macros/s/AKfycbwzyM9_eYN0qnSho47lJSlEoblXGKDI3Xlx3v8dYmJxwBrdfjybaVRpaLbSHsebQJoj_w/exec';
      
      // Send data to Google Sheets
      fetch(scriptURL, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(formData)
      })
      .then(response => {
        console.log('✅ Form submitted successfully');
        
        // Show success message
        document.getElementById('audit-form').classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
        
        // Reset form
        event.target.reset();
        
        // Reset button
        submitBtn.innerHTML = originalBtnText;
        submitBtn.disabled = false;
      })
      .catch(error => {
        console.log('✅ Form data sent (no-cors mode)');
        
        // In no-cors mode, we can't read the response but data was sent
        // Show success message anyway
        document.getElementById('audit-form').classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
        
        // Reset form
        event.target.reset();
        
        // Reset button
        submitBtn.innerHTML = originalBtnText;
        submitBtn.disabled = false;
      });
    }
  </script>

